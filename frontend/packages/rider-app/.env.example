# Base URL for the REST API. In production this is the Front Door endpoint;
# leave empty to use the same origin (recommended behind Front Door).
VITE_API_BASE=

# Local dev only: where `vite dev` proxies /api to (a local `func start` host,
# or the live Front Door endpoint for read-only testing).
VITE_API_PROXY_TARGET=http://localhost:7071
