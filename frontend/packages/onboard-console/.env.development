# Dev defaults for `npm run dev:console` (Vite loads this in dev mode only).
#
# mock  = preview without Entra: fake sign-in + role-switcher widget.
#         Ignored in production builds (guarded by import.meta.env.DEV).
# msal  = real Entra sign-in locally. Requires VITE_ENTRA_* set (see
#         .env.example) and http://localhost:5174/console/ registered as a
#         SPA redirect URI on the app registration.
VITE_AUTH_MODE=mock
