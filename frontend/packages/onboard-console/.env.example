# REST API base. Empty = same origin (production, behind Front Door).
VITE_API_BASE=

# Entra ID (Azure AD) app registration for the MVTA OnBoard console.
# Client ID is the existing OnBoard app registration (see HANDOFF.md §3).
VITE_ENTRA_CLIENT_ID=7e5a35b1-dc1b-473d-987d-6942a7b4fae2
VITE_ENTRA_TENANT_ID=<your-tenant-id>

# The API scope the console requests a token for (exposed by the API app
# registration). Example: api://<api-app-id>/access_as_user
VITE_API_SCOPE=api://<api-app-id>/access_as_user

# Local dev only: proxy target for /api.
VITE_API_PROXY_TARGET=http://localhost:7071
